# =============================================================================
# RAILWAY DEPLOYMENT — Environment Variables
# =============================================================================
# Copy ke Railway dashboard: Project → Variables → New Variable
# PASTIKAN TIDAK ADA SPASI SETELAH = (Railway parse strict)
#
# Generate ADMIN_SESSION_SECRET:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# =============================================================================

# ── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
ALLOWED_ORIGIN=https://seruni-mumbul.netlify.app

# ── Admin Auth (HARUS di-set untuk production) ──────────────────────────────
# Session signing secret — min 32 chars
ADMIN_SESSION_SECRET=GENERATE_DENGAN_NODE_DI_ATAS_SIMPAN_DISINI

# Admin credentials — HARUS diganti dari default
ADMIN_USER=admindesa
# Ganti password ini SETELAH deploy untuk keamanan
ADMIN_PASS=ubah_password_ini_sekarang

# ── Supabase ─────────────────────────────────────────────────────────────────
# URL dari Supabase Project → Settings → API
SUPABASE_URL=https://wrfraskmawmciiutwcpx.supabase.co

# Service role key — JANGAN expose ke browser/client!
# DARI: Supabase Project → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=ISI_SERVICE_ROLE_KEY_DISINI

# ── QR Code Signing ─────────────────────────────────────────────────────────
# Minimal 32 chars untuk HMAC-SHA256
QR_SECRET=GENERATE_QR_SECRET_DISINI

# ── Fonnte WhatsApp (optional) ──────────────────────────────────────────────
# Dari https://fonnte.com — kosongkan jika tidak digunakan
FONNTE_KEY=

# ── Cloudflare Turnstile (optional) ─────────────────────────────────────────
# Dari https://dash.cloudflare.com/turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Rate Limiting ────────────────────────────────────────────────────────────
# In-memory, reset saat server restart (ok untuk moderate traffic)
# Untuk high traffic: upgrade ke Redis (belum dikonfigurasi)