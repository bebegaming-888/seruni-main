# Environment variables untuk development (copy ke .env untuk lokal)
# Untuk production: set secrets via deployment dashboard / CLI

# Admin credentials — untuk development LOCAL saja.
# Untuk production: set via Cloudflare Pages Secrets (bukan VITE_*).
VITE_ADMIN_USER=admindesa
VITE_ADMIN_PASS=admin123

# Fonnte WhatsApp API key (jangan di-commit ke git!)
# Untuk development: kosongkan. Untuk production: set via Cloudflare Pages Secrets.
VITE_FONNTE_KEY=

# QR payload HMAC-SHA256 secret
# Digunakan untuk menandatangani qr_payload saat approve surat.
# Set di browser env (VITE_QR_SECRET) dan Cloudflare Secrets (QR_SECRET).
# Minimal 32 karakter acak.
VITE_QR_SECRET=

# Cloudflare Turnstile site key (untuk proteksi login dari spam/bot)
# Daftar di: https://dash.cloudflare.com/turnstile
# Biarkan kosong untuk dev mode (CAPTCHA dinonaktifkan)
VITE_TURNSTILE_SITE_KEY=

# Supabase — untuk production
# Di-set via Cloudflare Pages secrets, BUKAN di .env publik
VITE_SUPABASE_URL=https://jnarzbkddjdrethfkxtn.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
# SUPABASE_SERVICE_ROLE_KEY: set via Cloudflare Pages Secrets (Edge Functions only)

# Web Push Notification (VAPID keys)
# Generate dengan: npx web-push generate-vapid-keys
# Public key → bisa di-commit (.env / deployment UI)
VITE_VAPID_PUBLIC_KEY=
# Private key → HANYA via Cloudflare Pages Secrets (bukan VITE_*, tidak di-commit!)

# RLS Security Token (admin API dari browser)
VITE_ADMIN_DB_TOKEN=mitradesa-secure-token-2024

# ═══════════════════════════════════════════════════════════════════════════════
# CLOUDFLARE PAGES SECRETS (Edge Functions only — set via dashboard)
# ═══════════════════════════════════════════════════════════════════════════════
# Perintah CLI untuk set secrets:
#   npx wrangler secret put SUPABASE_SERVICE_ROLE_KEY --project-name=seruni-mumbul
#   npx wrangler secret put ADMIN_SESSION_SECRET
#   npx wrangler secret put FONNTE_API_KEY
#   npx wrangler secret put ADMIN_WA_NUMBER
#   npx wrangler secret put JWT_SECRET
#   npx wrangler secret put QR_SECRET
#   npx wrangler secret put VAPID_PRIVATE_KEY
#   npx wrangler secret put VAPID_SUBJECT
#   npx wrangler secret put ADMIN_USER
#   npx wrangler secret put ADMIN_PASS
#
# Atau via dashboard: Cloudflare Pages → Project → Settings → Environment Variables
# Pastikan variable name SAMA PERSIS dengan yang digunakan di wrangler.toml/env:
#   - SUPABASE_SERVICE_ROLE_KEY
#   - ADMIN_SESSION_SECRET       ← HMAC signing key untuk admin session cookie
#   - FONNTE_API_KEY           ← Fonnte WhatsApp API token
#   - ADMIN_WA_NUMBER          ← Nomor WA admin untuk notifikasi cron
#   - JWT_SECRET               ← HMAC signing key untuk warga JWT token
#   - QR_SECRET               ← HMAC signing key untuk QR payload
#   - VAPID_PRIVATE_KEY       ← Web Push VAPID private key (PKCS8 base64)
#   - VAPID_SUBJECT           ← mailto: atau https:// URL untuk VAPID
#   - ADMIN_USER              ← Fixed admin username (fallback jika tidak ada di DB)
#   - ADMIN_PASS              ← Fixed admin password (fallback jika tidak ada di DB)