# Environment variables untuk development (copy ke .env untuk lokal)
# Untuk production: set secrets via Netlify Dashboard → Environment Variables

# ── ADMIN AUTH (Netlify Functions only — NOT VITE_*) ──────────────────────────
# Untuk production: set via Netlify Dashboard Secrets (bukan .env publik).
# VITE_* vars hanya untuk browser, tidak bisa dibaca oleh Netlify Functions.
ADMIN_USER=your-admin-username-here
ADMIN_PASS=your-admin-password-here

# ── WHATSAPP NOTIFICATIONS ────────────────────────────────────────────────────
# Fonnte API key — untuk development: kosongkan. Production: via Netlify Secrets.
VITE_FONNTE_KEY=your-fonnte-key-here

# ── ADMIN SESSION HMAC SECRET (SERVER-SIDE ONLY — H-01 Fix) ────────────────────
# H-01: Session signing moved to server-side (/api/auth/sign-session).
# VITE_ADMIN_SESSION_SECRET NO LONGER NEEDED in browser bundle.
# ADMIN_SESSION_SECRET (server-only): set via Netlify Secrets or .dev.vars.
# Must be at least 32 characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# This secret is NEVER exposed to the browser.
# For local dev: add ADMIN_SESSION_SECRET=your-secret to .dev.vars

# ── QR PAYLOAD HMAC SECRET ─────────────────────────────────────────────────────
# Digunakan untuk menandatangani qr_payload saat approve surat.
# Set via Netlify Secrets untuk production.
VITE_QR_SECRET=your-qr-secret-here

# ── SUPABASE MANAGEMENT API ─────────────────────────────────────────────────
# Personal Access Token for Supabase Management API (scripts/apply-wilayah.cjs, etc.)
# Generate at: https://supabase.com/dashboard/account/tokens
# NEVER commit this token. Set via environment or .dev.vars for local dev.
SUPABASE_PERSONAL_ACCESS_TOKEN=your-supabase-personal-access-token-here

# ── SUPABASE ─────────────────────────────────────────────────────────────────
# Anon key: aman di browser (dilindungi RLS). Url: dari project Supabase.
VITE_SUPABASE_URL=https://wrfraskmawmciiutwcpx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6IndyZnJhc2ttYXdtY2lpdXR3Y3B4Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzk0ODMzNzksImV4cCI6MjA5NTA1OTM3OX0.5u2Jj5kN5X5pPgMII8HI1ileh507pjdLwQV7UyKDCLM

# ── CLOUDFLARE TURNSTILE ──────────────────────────────────────────────────────
# Site key untuk proteksi login dari spam/bot.
# Daftar di: https://dash.cloudflare.com/turnstile
# Biarkan kosong untuk dev mode.
VITE_TURNSTILE_SITE_KEY=

# ── WEB PUSH (VAPID keys) ─────────────────────────────────────────────────────
# Generate dengan: npx web-push generate-vapid-keys
# Public key → bisa di-commit
VITE_VAPID_PUBLIC_KEY=

# ── SENTRY ERROR TRACKING ─────────────────────────────────────────────────────
# Daftar gratis di: https://sentry.io (5.000 errors/bulan free tier)
# Biarkan kosong untuk dev mode. Production: via Netlify Secrets.
VITE_SENTRY_DSN=

# ── CORS ALLOWED ORIGIN ────────────────────────────────────────────────────────
# Domain production untuk CORS di Netlify Functions.
# Set via Netlify Dashboard → Environment Variables (production).
ALLOWED_ORIGIN=https://seruni-mumbul.netlify.app

# ── DEV MODE LOGIN BYPASS ─────────────────────────────────────────────────────
# AKTIFKAN HANYA UNTUK DEVELOPMENT (non-production).
# Jika true: fixed admin (ADMIN_USER/ADMIN_PASS) bisa login langsung
# dari browser TANPA edge function (berguna saat Netlify Functions tidak tersedia).
# JANGAN aktifkan di production — ini bypass server-side auth.
VITE_DEV_LOGIN_ENABLED=false