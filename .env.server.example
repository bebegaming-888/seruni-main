# Local API Server Environment Variables
# Copy this file to .env.local and fill in the values

# Server port
PORT=3001

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin credentials (server-side)
ADMIN_USER=admindesa
ADMIN_PASS=admin123

# WhatsApp (Fonnte)
FONNTE_API_KEY=your-fonnte-key

# QR Signing
QR_SECRET=your-qr-secret

# WhatsApp Admin
ADMIN_WA_NUMBER=6281234567890

# CORS (allow all in development)
ALLOWED_ORIGIN=*

# Build hash (for health check)
VITE_BUILD_HASH=dev